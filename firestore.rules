rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Chat sessions - nested under users
      match /chatSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Memories - nested under users
      match /memories/{memoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Error logs (for debugging)
    match /errors/{errorId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
    
    // Admin collection - ALL access via Cloud Functions only
    // This ensures API keys and settings can never be accessed directly
    match /admin/{document=**} {
      allow read, write: if false;
    }
    
    // Analytics collection - ALL access via Cloud Functions only
    // Ensures data integrity and prevents tampering
    match /analytics/{document=**} {
      allow read, write: if false;
    }
  }
}
