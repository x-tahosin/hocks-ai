# HOCKS AI Environment Configuration
# Copy this file to .env and fill in your values

# Firebase Configuration (get from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=hocks-ai-main.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=hocks-ai-main
VITE_FIREBASE_STORAGE_BUCKET=hocks-ai-main.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Gemini API Key (get from https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_gemini_api_key

# Functions URL (leave empty for local development, set for production)
VITE_FUNCTIONS_URL=

# Admin Email
VITE_ADMIN_EMAIL=x.tahosin@gmail.com
